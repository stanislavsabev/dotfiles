va() {
    if [ $# -eq 0 ]; then
        source venv/bin/activate
        return
    fi

    case "$1" in 
        be)
            va-be
            ;;
        migration | migrations)
            va-migrations
            ;;
        soa)
            va-soa  
            ;;
        *)
            echo "Unknown venv!"
            ;;
    esac
}

